{
  "id": "nice-flo",
  "name": "Nice FLO (fixed-code) / FLOR-S (rolling)",
  "category": "subghz",
  "typical_frequencies_hz": [433920000, 868500000],
  "modulation": "OOK",
  "typical_bit_rate": 1400,
  "fingerprint": {
    "regex_patterns": [
      "Nice[\\s_-]?FLO",
      "Nice[\\s_-]?FLOR"
    ],
    "bit_length_range": [12, 52]
  },
  "decoder": {
    "fields": {
      "key": {"regex": "Key:\\s*(0x[0-9a-fA-F]+)"},
      "bit": {"regex": "Bit:\\s*(\\d+)"}
    }
  },
  "typical_devices": [
    "Nice gate / garage remotes (FLO1, FLO2, FLO4)",
    "Nice FLOR-S rolling-code remotes",
    "commercial gate automation (Italian / European market)"
  ],
  "security_notes": "FLO variants are fixed-code and trivially replayable. FLOR-S is rolling-code with known weaknesses in older firmware.",
  "references": [
    "https://www.niceforyou.com/",
    "https://docs.flipper.net/sub-ghz/protocols"
  ],
  "packs": ["garage", "access-control"]
}
